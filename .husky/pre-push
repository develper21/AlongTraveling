#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Running pre-push checks..."

# Run backend linting
echo "🔍 Running backend linting..."
cd backend
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Backend linting failed"
  exit 1
fi

# Build frontend
echo "🏗️  Building frontend..."
cd ../frontend
npm run build
if [ $? -ne 0 ]; then
  echo "❌ Frontend build failed"
  exit 1
fi

echo "✅ Pre-push checks passed!"
